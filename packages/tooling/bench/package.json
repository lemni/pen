{
  "name": "@pen/bench",
  "version": "0.0.0",
  "description": "Performance benchmarks for Pen",
  "license": "LICENSE.md",
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./src/index.ts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./src/index.ts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./src/index.ts",
  "files": [
    "dist",
    "src"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "bench": "tsx src/run.ts",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "devDependencies": {
    "@pen/ai": "workspace:*",
    "@pen/ai-autocomplete": "workspace:*",
    "@pen/core": "workspace:*",
    "@pen/crdt-yjs": "workspace:*",
    "@pen/schema-default": "workspace:*",
    "@pen/test": "workspace:*",
    "@pen/types": "workspace:*",
    "@types/node": "^25.4.0",
    "tsup": "^8.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.3",
    "vitest": "^3.0.7",
    "yjs": "^13.6.0"
  }
}
