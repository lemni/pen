{
  "name": "@pen/preset-default",
  "version": "0.0.0",
  "description": "Default batteries-included editor preset for Pen",
  "license": "LICENSE.md",
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./src/index.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./src/index.ts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./src/index.ts",
  "files": [
    "dist",
    "src"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@pen/delta-stream": "workspace:*",
    "@pen/document-ops": "workspace:*",
    "@pen/shortcuts": "workspace:*",
    "@pen/types": "workspace:*",
    "@pen/undo": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.4.0",
    "typescript": "^5.7.3",
    "vitest": "^3.0.7"
  }
}
