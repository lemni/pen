{
  "name": "@pen/core",
  "version": "0.0.0",
  "description": "Headless, extension-first editor engine for human-AI co-authoring",
  "license": "LICENSE.md",
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./src/index.ts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./src/index.ts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./src/index.ts",
  "files": [
    "dist",
    "src"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@pen/crdt-yjs": "workspace:*",
    "@pen/delta-stream": "workspace:*",
    "@pen/document-ops": "workspace:*",
    "@pen/schema-default": "workspace:^",
    "@pen/shortcuts": "workspace:*",
    "@pen/types": "workspace:*",
    "@pen/undo": "workspace:*"
  },
  "devDependencies": {
    "@pen/input-rules": "workspace:*",
    "tsup": "^8.4.0",
    "typescript": "^5.7.3",
    "vitest": "^3.0.7",
    "yjs": "^13.6.29"
  }
}
