{
  "name": "@pen/playground",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:backend": "tsx watch --clear-screen=false --exclude \"../packages/**/dist/**\" --tsconfig tsconfig.server.json server/index.ts",
    "dev:e2e": "vite --host 127.0.0.1 --port 4173 --strictPort",
    "build": "vite build",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.server.json"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.58",
    "@pen/ai": "workspace:*",
    "@pen/ai-autocomplete": "workspace:*",
    "@pen/ai-skills": "workspace:*",
    "@pen/ai-tools": "workspace:*",
    "@pen/assets-memory": "workspace:^",
    "@pen/core": "workspace:*",
    "@pen/database": "workspace:*",
    "@pen/export-html": "workspace:*",
    "@pen/export-markdown": "workspace:*",
    "@pen/import-html": "workspace:*",
    "@pen/import-markdown": "workspace:*",
    "@pen/input-rules": "workspace:*",
    "@pen/preset-default": "workspace:*",
    "@pen/react": "workspace:*",
    "@pen/schema-default": "workspace:*",
    "@pen/shortcuts": "workspace:*",
    "@pen/types": "workspace:*",
    "ai": "^6.0.116",
    "dotenv": "^17.3.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.4.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "tsx": "^4.21.0",
    "typescript": "^5.7.3",
    "vite": "^6.2.0"
  }
}
